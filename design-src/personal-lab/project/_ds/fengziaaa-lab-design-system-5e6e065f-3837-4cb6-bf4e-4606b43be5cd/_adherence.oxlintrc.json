{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/cards/**",
              "components/data/**",
              "components/panel/**",
              "components/status/**",
              "ui_kits/ideas_board/**",
              "ui_kits/lab_cockpit/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Orbitron|Chakra Petch|Share Tech Mono|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Orbitron, Chakra Petch, Share Tech Mono, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConsoleLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:time|tag|msg|key|ref|className|style|children)$/]",
        "message": "<ConsoleLine> doesn't accept that prop. Declared props: time, tag, msg."
      },
      {
        "selector": "JSXOpeningElement[name.name='HudPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|accent|dot|live|right|notch|pad|bodyStyle|key|ref|className|style|children)$/]",
        "message": "<HudPanel> doesn't accept that prop. Declared props: label, accent, dot, live, right, notch, pad, bodyStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='IdeaCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|tag|tone|progress|active|key|ref|className|style|children)$/]",
        "message": "<IdeaCard> doesn't accept that prop. Declared props: title, subtitle, tag, tone, progress, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='NeonButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|size|icon|iconRight|disabled|key|ref|className|style|children)$/]",
        "message": "<NeonButton> doesn't accept that prop. Declared props: variant, tone, size, icon, iconRight, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='NeonButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline|ghost)$/]",
        "message": "<NeonButton> variant must be one of 'solid' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NeonButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<NeonButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|tone|height|showValue|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, tone, height, showValue."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuickTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|tone|key|ref|className|style|children)$/]",
        "message": "<QuickTile> doesn't accept that prop. Declared props: icon, label, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='RadialGauge'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|size|stroke|tone|label|key|ref|className|style|children)$/]",
        "message": "<RadialGauge> doesn't accept that prop. Declared props: value, max, size, stroke, tone, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|accent|dot|live|right|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: label, accent, dot, live, right."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|tone|align|reverse|glow|key|ref|className|style|children)$/]",
        "message": "<StatItem> doesn't accept that prop. Declared props: label, value, tone, align, reverse, glow."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatItem'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<StatItem> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|live|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: tone, dot, live."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|solid|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, solid."
      },
      {
        "selector": "JSXOpeningElement[name.name='Waveform'] > JSXAttribute > JSXIdentifier[name!=/^(?:bars|tone|height|animated|seed|key|ref|className|style|children)$/]",
        "message": "<Waveform> doesn't accept that prop. Declared props: bars, tone, height, animated, seed."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
